# Streamlit Cloud Secrets Template
# Copy this file to secrets.toml and fill in your values
# For local development, use .env file instead

# API Configuration (required for cloud deployment)
API_BASE_URL = "https://your-api-endpoint.com"

# xAI API Key (if running embedded API)
XAI_API_KEY = "your-xai-api-key"

# Optional: HuggingFace Token for faster model downloads
HF_TOKEN = "your-huggingface-token"
